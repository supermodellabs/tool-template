# Stack-agnostic baseline. Extend this per-tool — Deno, Go, Node, Rust, etc.
# all add their own ignores on top. Keep this section tight.

# ── Secrets & local config ─────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
secrets/
credentials/

# ── OS cruft ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor & IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.netrwhist

# ── Logs & temp ────────────────────────────────────────────────────────
*.log
.cache/
tmp/
.tmp/

# ── Local agent / tooling state ────────────────────────────────────────
# Keep agent CONTEXT files (AGENTS.md, .claude/skills, etc.) tracked.
# Ignore only ephemeral local state.
.claude/settings.local.json
.opencode/settings.local.json

# ── Stack-specific ─────────────────────────────────────────────────────
# Add ignores for the language(s) and frameworks this tool actually uses.
# Examples:
#   Deno:   /bin/  (compiled binaries)
#   Node:   node_modules/  .pnp/  *.tsbuildinfo
#   Go:     /dist/  *.test  *.out  vendor/
#   Rust:   /target/  Cargo.lock  (binaries only)
